@model IEnumerable<Supplier>

<div class="container">

    <h3>Suppliers</h3>

    <button class="btn btn-primary"
            data-bs-toggle="modal"
            data-bs-target="#supplierModal"
            onclick="clearForm()"
            title="Create a new supplier">

        Add Supplier

    </button>

    <div class="table-responsive mt-3">
        <table class="table table-bordered">

            <thead>
                <tr>

                    <th>Name</th>
                    <th>Email</th>
                    <th>Contact</th>
                    <th>Tax Id</th>
                    <th>Address</th>
                    <th>Action</th>

                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.Name</td>
                        <td>@item.Email</td>
                        <td>@item.ContactNumber</td>
                        <td>@item.TaxId</td>
                        <td>
                            @if (item.Address != null)
                            {
                                @($"{item.Address.Street}, {item.Address.City}, {item.Address.Country}")
                            }
                            else
                            {
                                <span class="text-muted">No Address</span>
                            }
                        </td>

                        <td>

                            <button class="btn btn-warning"
                                    onclick="editSupplier(@item.SupplierId)"
                                    title="Edit this supplier">
                                Edit
                            </button>

                            <button class="btn btn-danger"
                                    onclick="if(confirm('Are you sure you want to delete this supplier?')) { deleteSupplier(@item.SupplierId) }"
                                    title="Delete this supplier">
                                Delete
                            </button>

                        </td>

                    </tr>
                }

            </tbody>

        </table>
    </div>

</div>

<partial name="_SupplierModal" />