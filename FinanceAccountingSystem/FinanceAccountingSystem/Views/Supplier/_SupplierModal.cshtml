<div class="modal fade" id="supplierModal">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header">
                <h5>Supplier</h5>
            </div>

            <div class="modal-body">

                <input type="hidden" id="SupplierId" name="SupplierId" />

                <div class="form-group">
                    <label>Name</label>
                    <input id="Name" name="Name" class="form-control" required />
                    <span class="text-danger" id="SupplierNameError"></span>
                </div>

                <div class="form-group mt-2">
                    <label>Email</label>
                    <input id="Email" name="Email" class="form-control" required type="email" />
                    <span class="text-danger" id="SupplierEmailError"></span>
                </div>

                <div class="form-group mt-2">
                    <label>Contact</label>
                    <input id="ContactNumber" name="ContactNumber" class="form-control" required />
                    <span class="text-danger" id="SupplierContactError"></span>
                </div>

                <div class="form-group mt-2">
                    <label>Tax Id</label>
                    <input id="TaxId" name="TaxId" class="form-control" />
                </div>

                <div class="form-group mt-2">
                    <label>Address</label>
                    <select id="SupplierAddressId" name="AddressId" class="form-control" required>
                        <option value="">Select Address</option>
                        @if (ViewBag.AddressList != null)
                        {
                            foreach (var addr in ViewBag.AddressList)
                            {
                                <option value="@addr.AddressId">@addr.Street, @addr.City, @addr.Country</option>
                            }
                        }
                    </select>
                    <span class="text-danger" id="SupplierAddressIdError"></span>
                </div>

            </div>

            <div class="modal-footer">

                <button type="button" class="btn btn-success"
                        onclick="saveSupplier()">
                    Save
                </button>

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Close
                </button>

            </div>

        </div>
    </div>
</div>
