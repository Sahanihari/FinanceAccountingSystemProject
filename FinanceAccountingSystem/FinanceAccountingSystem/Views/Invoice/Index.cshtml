@model IEnumerable<FinanceAccountingSystem.Models.Invoice>

<div class="container">

    <h3>Invoice List</h3>

    <a href="/Invoice/Create" class="btn btn-primary" title="Create a new invoice">
        Create Invoice
    </a>

    <div class="table-responsive mt-3">
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Invoice Number</th>
                    <th>Date</th>
                    <th>Supplier</th>
                    <th>Customer</th>
                    <th>Amount</th>
                    <th>Tax</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.InvoiceNumber</td>
                        <td>@(item.InvoiceDate.HasValue ? item.InvoiceDate.Value.ToString("yyyy-MM-dd") : "")</td>
                        <td>@(item.Supplier != null ? item.Supplier.Name : item.SupplierId.ToString())</td>
                        <td>@(item.Customer != null ? item.Customer.Name : item.CustomerId.ToString())</td>
                        <td>@(item.Amount.HasValue ? item.Amount.Value.ToString("C") : "")</td>
                        <td>@(item.TaxAmount.HasValue ? item.TaxAmount.Value.ToString("C") : "")</td>
                        <td>@(item.TotalAmount.HasValue ? item.TotalAmount.Value.ToString("C") : "")</td>
                        <td>
                            <a href="/Invoice/Edit/@item.InvoiceId" class="btn btn-warning" title="Edit this invoice">Edit</a>
                            <form action="/Invoice/Delete/@item.InvoiceId" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-danger" title="Delete this invoice" onclick="return confirm('Are you sure you want to delete this invoice?');">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>